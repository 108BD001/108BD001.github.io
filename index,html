<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>108BD001 QSL</title>

<style>
body {
    margin:0;
    font-family:Arial;
    background:#0b0f1a;
    color:white;
}

/* UKŁAD GŁÓWNY */
.wrapper {
    display:flex;
    justify-content:center;
    align-items:flex-start;
    gap:20px;
    padding:20px;
    flex-wrap:wrap;
}

/* QSL OBRAZ */
.qsl {
    max-width:800px;
    width:100%;
    border-radius:10px;
}

/* PANEL PRAWO */
.panel {
    background:#e6e6e6;
    color:black;
    padding:15px;
    width:260px;
    border-radius:10px;
    font-size:14px;
}

/* BOX */
.box {
    background:#f5f5f5;
    border:1px solid #ccc;
    padding:8px;
    margin-bottom:8px;
    border-radius:5px;
}

/* GRID */
.row {
    display:flex;
    gap:5px;
}

.small {
    flex:1;
}

/* PRZYCISK */
.button {
    display:block;
    text-align:center;
    margin:20px auto;
    padding:15px;
    background:red;
    color:white;
    text-decoration:none;
    font-weight:bold;
    width:250px;
    border-radius:5px;
}

/* MOBILE */
@media(max-width:900px){
    .wrapper {
        flex-direction:column;
        align-items:center;
    }
}
</style>
</head>

<body>

<div class="wrapper">

    <!-- QSL -->
    <img src="qsl.jpg" class="qsl">

    <!-- PANEL -->
    <div class="panel" id="panel">

        <div class="box"><b>FROM:</b><br>108BD001<br>Zibi</div>

        <div class="box"><b>TO:</b><br id="to">---</div>

